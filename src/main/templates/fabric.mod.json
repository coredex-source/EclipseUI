{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "contact": {
    "homepage": "https://github.com/coredex-source/EclipseUI",
    "sources": "https://github.com/coredex-source/EclipseUI",
    "issues": "https://github.com/coredex-source/EclipseUI/issues"
  },
  "license": "${mod_license}",
  "icon": "assets/eclipseui/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "dev.eclipseui.fabric.EclipseUIFabric"
    ],
    "modmenu": [
      "dev.eclipseui.fabric.ModMenuIntegration"
    ]
  },
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "${supported_minecraft_versions}",
    "java": ">=${java_version}"
  },
  "suggests": {
    "modmenu": "*"
  },
  "custom": {
    "modmenu": {
      "badges": ["library"]
    }
  }
}
